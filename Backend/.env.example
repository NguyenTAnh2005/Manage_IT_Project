# ============================================
# DATABASE CONFIGURATION (.env.example)
# Copy file này thành .env và điền giá trị thực
# ============================================

# PostgreSQL connection string với async driver (asyncpg)
# Format: postgresql+asyncpg://username:password@host:port/database_name
# Ví dụ:  postgresql+asyncpg://postgres:mypassword@localhost:5432/QTDA
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/QTDA

# ============================================
# JWT & SECURITY
# ============================================

# Secret key để ký JWT tokens - phải random và bảo mật
# Sinh random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-random-secret-key-here

# Access token hết hạn sau bao nhiêu phút
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token hết hạn sau bao nhiêu ngày
REFRESH_TOKEN_EXPIRE_DAYS=7

# Thuật toán JWT
ALGORITHM=HS256

# ============================================
# APPLICATION
# ============================================

# Tên ứng dụng
APP_NAME=IT Project Management System

# Debug mode (True/False)
DEBUG=True
