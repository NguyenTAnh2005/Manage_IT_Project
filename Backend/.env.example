# ========== DATABASE ===========
# DATABASE_URL format: postgresql+asyncpg://username:password@host:port/database_name
# +asyncpg = Dùng driver async (asyncpg) thay vì sync (psycopg2)
# 
# Hướng dẫn setup:
# 1. Cài PostgreSQL
# 2. Tạo database: CREATE DATABASE QuanTriDuAn;
# 3. Thay đổi username, password, host, port theo config của bạn
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/QuanTriDuAn

#=========== SECURITY & JWT =========
# SECRET_KEY: Dùng để sign JWT token
# Tạo key mạnh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_replace_me

ALGORITHM=HS256
# Token hết hạn sau 1 ngày (1440 phút)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============= FRONTEND (cho CORS) ============
# URL của frontend (dùng cho CORS headers)
FRONTEND_URL=http://localhost:5500

# =============== EMAIL (Optional) ===============
# Dùng cho gửi email (reset password, etc)
# Để trống nếu không cần
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password

# =============== APP CONFIG ===============
# DEBUG: True = show lỗi chi tiết (development), False = ẩn lỗi (production)
DEBUG=True
PROJECT_NAME=Quản Lý Dự Án CNTT
